# Copiază acest fișier în .env și completează valorile.
# .env nu se comite în git (rămâne local).

# ---------- Firebase (opțional) ----------
# Pentru logare cu Firebase Auth (recomandat la hostare, HTTPS).
# 1. Creează proiect pe https://console.firebase.google.com/
# 2. Activează Authentication → Email/Password
# 3. Din Project Settings (roata) → General → "Your apps" → copiază config

VITE_USE_FIREBASE=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Când pui VITE_USE_FIREBASE=true, adaugă emailurile admin în AuthContext.tsx (ADMIN_EMAILS)
# și creează utilizatorii în Firebase Console → Authentication → Users.

# ---------- Bază de date (opțional, pentru securitate) ----------
# Dacă setezi DATABASE_URL, serverul folosește PostgreSQL în loc de SQLite/JSON.
# Exemplu: postgresql://utilizator:parola@host:5432/nume_baza
# Pe server (Railway, Render, etc.) adaugă variabila DATABASE_URL din panoul de control.
# DATABASE_URL=postgresql://...

# ---------- API (la hostare) ----------
# URL-ul serverului tău Node (pentru API și pentru imaginile din /uploads). În dev nu e nevoie (proxy Vite).
# Setează la adresa unde rulează backend-ul, ex: https://api.domeniul.ro sau https://domeniul.ro
# VITE_API_URL=https://api.domeniul.ro

# ---------- Securitate (backend) ----------
# Secret pentru semnarea JWT-urilor admin. Generează unul: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=your-64-char-hex-secret
# Dacă JWT_SECRET nu este setat, serverul va genera unul persistent local în server/.runtime-secrets.json (ignorat în git).
# Pentru producție este recomandat să setezi explicit JWT_SECRET în mediul de deploy.
# TTL token admin (implicit 12h)
# ADMIN_TOKEN_TTL=12h
# Body JSON maxim în MB (implicit 25). Pentru upload video base64, setează mai mare decât limita fișierului.
# Exemplu: dacă SITE_CONTENT_UPLOAD_MAX_MB=60, pune cel puțin JSON_BODY_LIMIT_MB=100.
# JSON_BODY_LIMIT_MB=100
# Originile permise pentru CORS (virgulă). Adaugă domeniul de producție.
# ALLOWED_ORIGINS=http://localhost:1573,http://localhost:5173,http://localhost:3001,https://domeniul.ro
# Opțional: regex pentru subdomenii, separate prin virgulă (ex: ^https:\/\/[a-z0-9-]+\.domeniul\.ro$)
# ALLOWED_ORIGIN_PATTERNS=
# Parolă admin default DOAR hash-uită bcrypt (evită plaintext)
# DEFAULT_ADMIN_PASSWORD_HASH=$2b$12$...

# ---------- Notificări email (mesaje Contact) ----------
# Ca mesajele de pe pagina Contact să fie trimise pe email, setează SMTP_USER și SMTP_PASS.
# Pentru Gmail: folosește un "App Password" (Cont Google → Securitate → Parole pentru aplicații).
CONTACT_NOTIFICATIONS_EMAIL=info@rightmob.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Alternativ (aceeași valoare ca App Password) dacă preferi să nu folosești SMTP_PASS
# SMTP_APP_PASSWORD=
# Opțional: adresa de la care se trimite (implicit: SMTP_USER)
SMTP_FROM=noreply@rightmob.com

# ---------- Date companie (frontend) ----------
# Aceste valori se afișează în Contact/Footer/Header.
VITE_COMPANY_PHONE=+373 78 68 53 63
VITE_WHATSAPP_NUMBER=37378685363
VITE_VIBER_NUMBER=37378685363
