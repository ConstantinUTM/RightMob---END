# Copiază acest fișier în .env și completează valorile.
# .env nu se comite în git (rămâne local).

# ---------- Firebase (opțional) ----------
# Pentru logare cu Firebase Auth (recomandat la hostare, HTTPS).
# 1. Creează proiect pe https://console.firebase.google.com/
# 2. Activează Authentication → Email/Password
# 3. Din Project Settings (roata) → General → "Your apps" → copiază config

VITE_USE_FIREBASE=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Când pui VITE_USE_FIREBASE=true, adaugă emailurile admin în AuthContext.tsx (ADMIN_EMAILS)
# și creează utilizatorii în Firebase Console → Authentication → Users.

# ---------- API (la hostare) ----------
# URL-ul serverului tău Node. În dev nu e nevoie (proxy Vite).
# VITE_API_URL=https://api.domeniul.ro

# ---------- Notificări email (mesaje Contact) ----------
# Ca mesajele de pe pagina Contact să fie trimise pe email, setează SMTP_USER și SMTP_PASS.
# Pentru Gmail: folosește un "App Password" (Cont Google → Securitate → Parole pentru aplicații).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Opțional: adresa de la care se trimite (implicit: SMTP_USER)
# SMTP_FROM=noreply@domeniul.ro
